    </a>

  <button id="hamburger" aria-label="Toggle menu">
    <span></span>
    <span></span>
    <span></span>
  </button>
 <ul id="nav-links">
    <li><a href="/about">About</a></li>
    <li><a href="/portfolio">Portfolio</a></li>
    <li><a href="/blog">Blog</a></li>
    <li>
      <a href="https://github.com/Tucci-net">
        <img id="githublogo" src="assets/github-static.png" height="20rem" alt="Github">
